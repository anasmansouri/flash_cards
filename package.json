{
  "name": "flash-cards-webapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "javac backend-java/src/Main.java -d backend-java/out && java -cp backend-java/out Main",
    "dev:client": "vite",
    "build": "vite build",
    "test": "javac backend-java/src/Main.java -d backend-java/out"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.2"
  }
}
